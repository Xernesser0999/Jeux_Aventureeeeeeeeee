"sentence": {
"choice": true,
"sentences": [
{
"id": 4,
"speaker": "O_OPERATOR",
"text": {
"en": "Patisserie Angelica, hello. What can I do for you?",
"ru": "~041A~043E~043D~0434~0438~0442~0435~0440~0441~043A~0430~044F ~0410~043D~0436~0435~043B~0438~043A~0430, ~043F~0440~0438~0432~0435~0442. ~0427~0442~043E ~044F ~043C~043E~0433~0443 ~0441~0434~0435~043B~0430~0442~044C ~0434~043B~044F ~0432~0430~0441?",
"fr": "Patisserie Angelica, bonjour. Que puis-je faire pour vous ?",
"it": "Pasticceria Angelica, buongiorno. Che posso fare per voi ?",
"de": "Patisserie Angelica hier. Wie kann ich Ihnen helfen?",
"tw": "~7CD5~9EDE~7576~6B78~FF0C~4F60~597D~6211~80FD~70BA~4F60~505A~4EC0~9EBC~FF1F",
"ja": "~30D1~30C6~30A3~30B9~30EA~30FC~30A2~30F3~30B8~30A7~30EA~30AB~3001~3053~3093~306B~3061~306F~3002~3069~3046~3044~3046~3054~7528~4EF6~3067~3059~304B~FF1F",
"ko": "~D30C~D2F0~C250 ~C548~C824~B9AC~CE74, ~C548~B155. ~B0B4~AC00 ~B2F9~C2E0~C744 ~C704~D574 ~BB34~C5C7~C744 ~D560 ~C218?",
"cn": "~4F60~597D~3002~6211~80FD~4E3A~4F60~505A~4EC0~4E48~FF1F"
},
"sentences": [
{
"id": 5,
"choice": true,
"do_not_say": true,
"text": {
"en": "You know... I really want to throw a pie to Botul.",
"ru": "~0417~043D~0430~0435~0442~0435, ~0443 ~043C~0435~043D~044F ~043D~0435~043F~0440~0435~043E~0434~043E~043B~0438~043C~043E~0435 ~0436~0435~043B~0430~043D~0438~0435 ~0448~0432~044B~0440~043D~0443~0442~044C ~043F~0438~0440~043E~0433~043E~043C ~0432 ~0411~043E~0442~044E~043B~044F.",
"fr": "Vous savez... j'ai trop envie d'entarter Botul.",
"it": "Vi avverto che ho voglia di gettare una torta in faccia di Botul.",
"de": "Wissen Sie... ich würde wirklich gerne mit einem Kuchen nach Botul werfen.",
"tw": "~4F60~77E5~9053...~6211~771F~7684~60F3~628A~4E00~500B~9921~9905~7D66Botul~3002",
"ja": "~3042~306A~305F~306F~77E5~3063~3066~3044~308B...~79C1~306F~672C~5F53~306B~30DC~30C8~30A5~30EB~306B~30D1~30A4~3092~6295~3052~305F~3044~3002",
"ko": "~B108~B3C4 ~C54C~B2E4~C2DC~D53C .. ~B098~B294 ~D30C~C774~B97C Botul~C5D0 ~B358~C9C0~ACE0 ~C815~B9D0~B85C ~C2F6~B2E4.",
"cn": "~4F60~77E5~9053......~6211~771F~7684~60F3~5411Botul~6254~9985~997C~3002"
},
"sentences": [
{
"id": 6,
"speaker": "O_HERO",
"text": {
"en": "You know... uh... if you deliver?",
"ru": "~0417~043D~0430~0435~0442~0435, ~044D~044D~043C.., ~0430 ~0443 ~0432~0430~0441 ~0435~0441~0442~044C ~0434~043E~0441~0442~0430~0432~043A~0430?",
"fr": "Vous savez... euh... si vous livrez?",
"it": "Voi sapete... euh... se voi portate ?",
"de": "Wissen Sie... ähm... liefern Sie auch?",
"tw": "~4F60~77E5~9053~55CE~FF1F",
"ja": "~3042~306A~305F~304C~77E5~3063~3066~3044~308B~306E~306F...~3048~3048~3001~3082~3057~3042~306A~305F~304C~7D0D~54C1~3059~308C~3070~FF1F",
"ko": "~B108 ... ~BC30~B2EC ~D560 ~C218 ~C788~B2C8?",
"cn": "~4F60~77E5~9053......~5443......~5982~679C~4F60~9001~8D27~FF1F"
},
"sentences": [
{
"id": 7,
"speaker": "O_OPERATOR",
"text": {
"en": "Yes sir, we even have a quick service.",
